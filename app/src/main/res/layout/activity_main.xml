<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="🌟 学习乐园 🌟"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/app_primary"
            android:fontFamily="sans-serif-rounded"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="48dp"
            android:text="一年级趣味学习小助手"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"/>

        <!-- 语文卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardChinese"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/card_chinese">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="28dp"
                android:paddingEnd="24dp"
                android:clickable="false"
                android:focusable="false">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:gravity="center"
                    android:textSize="44sp"
                    android:text="📖"
                    android:clickable="false"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:clickable="false">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="语 文"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white"
                        android:fontFamily="sans-serif-rounded"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="看拼音 · 认汉字"
                        android:textSize="14sp"
                        android:textColor="#FFE8E8"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="24sp"
                    android:textColor="#FFE8E8"
                    android:clickable="false"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 数学卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMath"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/card_math">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="28dp"
                android:paddingEnd="24dp"
                android:clickable="false"
                android:focusable="false">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:gravity="center"
                    android:textSize="44sp"
                    android:text="🔢"
                    android:clickable="false"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:clickable="false">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="数 学"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white"
                        android:fontFamily="sans-serif-rounded"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="加减法 · 快速算"
                        android:textSize="14sp"
                        android:textColor="#E8F0FF"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="24sp"
                    android:textColor="#E8F0FF"
                    android:clickable="false"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 英语卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEnglish"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/card_english">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="28dp"
                android:paddingEnd="24dp"
                android:clickable="false"
                android:focusable="false">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:gravity="center"
                    android:textSize="44sp"
                    android:text="🔤"
                    android:clickable="false"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:clickable="false">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="英 语"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-rounded"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="看图 · 选单词"
                        android:textSize="14sp"
                        android:textColor="#44AA66"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="24sp"
                    android:textColor="#44AA66"
                    android:clickable="false"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:text="每天练习，进步一点点！💪"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
